# Solana
SOLANA_RPC_URL=https://api.devnet.solana.com
SOLANA_PRIVATE_KEY=         # base58 encoded private key
DRIFT_ENV=devnet            # devnet | mainnet-beta

# Helius (mainnet RPC - get free key at helius.dev)
HELIUS_API_KEY=

# Telegram alerts (optional - get token from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Strategy params — GA-optimized (50pop × 30gen)
# Backtest results: Sharpe=5.77, Calmar=7.88, MaxDD=0.73%, Return=+0.97% (90-day bear market)
MAX_LEVERAGE=3.83
FUNDING_THRESHOLD=0.0
DELTA_THRESHOLD=0.04
MAX_DRAWDOWN=0.1557
LIQUIDATION_BUFFER=0.30
REBALANCE_INTERVAL_MS=60000
NEGATIVE_FUNDING_EXIT_HOURS=136

# Market weights (must sum to 1.0)
# GA recommendation: 0% SOL (negative funding Jan-Mar 2026), 70% BTC, 30% ETH
SOL_WEIGHT=0.0
BTC_WEIGHT=0.7016
ETH_WEIGHT=0.2984

# Vault
VAULT_NAME=DeltaNeutralFundingVault
